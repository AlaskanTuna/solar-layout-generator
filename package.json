{
  "name": "solar-layout-generator",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "db:migrate": "npm exec --workspace=backend -- prisma migrate dev",
    "db:seed": "npm exec --workspace=backend -- prisma db seed",
    "format": "prettier --write .",
    "build": "npm run build --workspace=shared && npx prisma generate && npm run build --workspace=backend && npm run build --workspace=frontend",
    "start": "npm run start --workspace=backend",
    "heroku-postbuild": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.6.2"
  }
}
