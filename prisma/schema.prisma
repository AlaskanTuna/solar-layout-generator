generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_DATABASE_URL")
}

enum LocationStatus {
  processing
  ready
  failed
}

enum ProjectStatus {
  draft
  layout_saved
  analysis_saved
}

model Location {
  id                    String         @id @default(uuid())
  lat                   Float
  lng                   Float
  status                LocationStatus @default(processing)
  buildingInsightsJson  Json?
  rgbImageUrl           String?
  monthlyFluxPath       String?
  maskPath              String?
  annualFluxPath        String?
  dsmPath               String?
  createdAt             DateTime       @default(now())

  projects              Project[]
}

model Project {
  id              String        @id @default(uuid())
  userId          String
  locationId      String
  name            String
  status          ProjectStatus @default(draft)
  editedLayout    Json?
  analysisConfig  Json?
  analysisResults Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  location        Location      @relation(fields: [locationId], references: [id])
}

model TariffConfig {
  id              String @id @default(uuid())
  tariffVersion   String @unique
  rates           Json
  thresholds      Json
  eeiTable        Json
  afaRateDefault  Float
  defaults        Json?
}
