# Google APIs
GOOGLE_SOLAR_API_KEY=your_google_solar_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id      # Create at console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_SECRET=your_google_oauth_secret

# Supabase
SUPABASE_PROJECT_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Auth
SITE_URL=https://your-production-url.com

# Database
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Frontend
FRONTEND_PORT=5173
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Backend
BACKEND_PORT=3001

# CORS
FRONTEND_URL=http://localhost:5173                      # Allowed origin for CORS; defaults to http://localhost:5173

# PDF Export Service (see docs/TRD.md §14)
PDF_TOKEN_SECRET=change_me_to_a_32_plus_char_hex_secret # HMAC secret for short-lived PDF export JWTs (backend-only)
VITE_PDF_EXPORT_URL=https://your-pdf-service.vercel.app # Vercel function URL; baked into frontend at build time
VITE_FRONTEND_ORIGIN=http://localhost:5173              # Used to construct the preview URL; set to prod origin on Heroku

# Deployment
HEROKU_PORT=                                            # Set by Heroku automatically; do not set locally
NODE_ENV=                                               # Set to "production" on Heroku; defaults to "development"
