# Values that appear both backend-side and frontend-side (VITE_-prefixed) use
# `${VAR}` interpolation so each secret is written once. Override any derived
# value by assigning it a literal (e.g. a split Google key for Solar vs Maps).
# Requires `dotenv-expand` (backend) and Vite's built-in `dotenv-expand` (frontend).

# Google APIs — one key if Solar + Maps are enabled in the same Cloud project
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SOLAR_API_KEY=${GOOGLE_API_KEY}
GOOGLE_MAPS_API_KEY=${GOOGLE_API_KEY}
VITE_GOOGLE_MAPS_API_KEY=${GOOGLE_API_KEY}

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id      # Create at console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_SECRET=your_google_oauth_secret

# Supabase
SUPABASE_PROJECT_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_SUPABASE_URL=${SUPABASE_PROJECT_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Supabase Auth
SITE_URL=https://your-production-url.com

# Database
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Ports
BACKEND_PORT=3001
FRONTEND_PORT=5173

# CORS / frontend origin (backend uses this for CORS; PDF service uses to validate preview URL)
FRONTEND_URL=http://localhost:5173

# PDF Export Service (see docs/TRD.md §14)
PDF_TOKEN_SECRET=change_me_to_a_32_plus_char_hex_secret # HMAC secret for short-lived PDF export JWTs (backend-only)
VITE_PDF_EXPORT_URL=https://your-pdf-service.vercel.app # Vercel function URL; baked into frontend at build time

# Deployment
HEROKU_PORT=                                            # Set by Heroku automatically; do not set locally
NODE_ENV=                                               # Set to "production" on Heroku; defaults to "development"
