# VITE_-prefixed entries use dotenv-expand interpolation — set the canonical value once
# and the client-side variant auto-derives. Vite requires the VITE_ prefix for security.

# Google APIs (single key with Solar + Maps APIs enabled in the same Cloud project)
GOOGLE_API_KEY=your_google_api_key
VITE_GOOGLE_API_KEY=${GOOGLE_API_KEY}

# Gemini Chat Assistant (Vertex AI primary, API key fallback)
# At least one of GOOGLE_CLOUD_PROJECT or GEMINI_API_KEY must be set or the backend
# will refuse to boot. Vertex auth uses Application Default Credentials (gcloud auth
# application-default login locally; service account on Heroku). API key from
# https://aistudio.google.com/apikey or any GCP project with Generative Language API enabled.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=global
GEMINI_API_KEY=your_gemini_api_key_fallback
CHAT_MODEL=gemini-3.1-flash-lite

# Google OAuth (console.cloud.google.com/apis/credentials)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_SECRET=your_google_oauth_secret

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Supabase Auth
# SITE_URL is where Supabase redirects users after email confirmation, password reset, etc.
# Set to your custom domain in production (e.g. https://yourapp.com), or your deployed
# app origin if you don't have a custom domain. Local dev uses http://localhost:5173.
SITE_URL=https://your-production-url.com

# Production canonical apex domain (hostname only, no protocol or path).
# When set in production, the backend 301-redirects the apex domain over HTTP
# and the www subdomain to https://<APEX_DOMAIN>.
# Leave empty for local dev, CI, or deployments without a custom domain.
APEX_DOMAIN=

# Ports
BACKEND_PORT=3001
FRONTEND_PORT=5173

# CORS / frontend origin
FRONTEND_URL=http://localhost:5173

# PDF Export Service
PDF_TOKEN_SECRET=your_token_secret
PDF_EXPORT_URL=your_service_url
VITE_PDF_EXPORT_URL=${PDF_EXPORT_URL}

# Resend Email Service
RESEND_API_KEY=your_resend_api_key

# Deployment (set by Heroku at runtime)
HEROKU_PORT=
NODE_ENV=
